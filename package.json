{
  "name": "micostskills-enterprise",
  "version": "1.0.0",
  "description": "MiCoSTSkills website and local student portal API",
  "main": "backend/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node backend/server.js",
    "build": "tailwindcss -c ./frontend/tailwind.config.js -i ./frontend/src/styles/input.css -o ./frontend/public/dist/output.css",
    "watch": "tailwindcss -c ./frontend/tailwind.config.js -i ./frontend/src/styles/input.css -o ./frontend/public/dist/output.css --watch",
    "check": "node --check backend/server.js && node --check frontend/public/assets/js/shared-components.js && node --check frontend/public/assets/js/elearning-script.js",
    "smoke": "node tests/smoke.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "playwright": "^1.57.0",
    "tailwindcss": "^3.4.19"
  }
}
